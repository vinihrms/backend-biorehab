{
	"compilerOptions": {
		"rootDir": "src",
		"outDir": "dist",
		"module": "nodenext",
		"target": "es2022",
		"types": ["node"],
		"sourceMap": true,
		"declaration": true,
		"declarationMap": true,
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,
		"strict": true,
		"verbatimModuleSyntax": false,
		"isolatedModules": true,
		"noUncheckedSideEffectImports": true,
		"moduleDetection": "force",
		"skipLibCheck": true,
		"ignoreDeprecations": "6.0"
	}
}

