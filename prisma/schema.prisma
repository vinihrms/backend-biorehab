datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum DataType {
  numeric
  integer
  boolean
  text
  choice
}

enum Papel {
  owner
  collector
  viewer
}

enum Sexo {
  MASCULINO
  FEMININO
  OUTRO
}

model Estudo {
  id        Int       @id @default(autoincrement())
  nome      String    @db.VarChar(100)
  sigla     String    @db.VarChar(10)
  descricao String?   @db.Text
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tipoVisitas   TipoVisita[]
  variaveis     Variavel[]
  participacoes ParticipacaoEstudo[]
  permissoes    PermissaoEstudo[]

  @@map("estudos")
}

model Usuario {
  id        Int       @id @default(autoincrement())
  email     String    @unique @db.VarChar(254)
  password  String    @db.VarChar(255)
  ra        String    @unique @db.VarChar(6)
  nome      String    @default("") @db.VarChar(150)
  isActive  Int       @default(1) @map("is_active") @db.TinyInt
  isAdmin   Boolean   @default(false) @map("is_admin")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  visitasCriadas  Visita[]
  medicoesCriadas Medicao[]
  permissoes      PermissaoEstudo[]

  @@map("usuarios")
}

model Participante {
  id         Int       @id @default(autoincrement())
  nome       String    @db.VarChar(30)
  telefone   String    @db.VarChar(20)
  sexo       Sexo
  nascimento DateTime  @db.Date
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  participacoes ParticipacaoEstudo[]

  @@map("participantes")
}

model TipoVisita {
  id        Int       @id @default(autoincrement())
  nome      String    @db.VarChar(100)
  descricao String?    @db.VarChar(200)
  estudoId  Int       @map("estudo_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  estudo  Estudo   @relation(fields: [estudoId], references: [id], onDelete: Cascade)
  visitas Visita[]

  @@map("tipo_visitas")
}

model Variavel {
  id        Int       @id @default(autoincrement())
  nome      String    @db.VarChar(100)
  unidade   String?   @db.VarChar(20)
  dataType  DataType  @default(numeric) @map("data_type")
  options   String?   @db.Text
  estudoId  Int       @map("estudo_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  estudo    Estudo    @relation(fields: [estudoId], references: [id], onDelete: Cascade)
  medicoes  Medicao[]

  @@map("variaveis")
}

model Visita {
  id                   Int       @id @default(autoincrement())
  data                 DateTime  @db.Date
  participacaoEstudoId Int       @map("participacao_estudo_id")
  tipoVisitaId         Int       @map("tipo_visita_id")
  createdBy            Int       @map("created_by")
  notes                String?   @db.Text
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  deletedAt            DateTime? @map("deleted_at")

  participacaoEstudo ParticipacaoEstudo @relation(fields: [participacaoEstudoId], references: [id], onDelete: Restrict)
  tipoVisita         TipoVisita         @relation(fields: [tipoVisitaId], references: [id], onDelete: Restrict)
  usuario            Usuario            @relation(fields: [createdBy], references: [id], onDelete: Restrict)

  medicoes       Medicao[]

  @@map("visitas")
}

model ParticipacaoEstudo {
  id             Int    @id @default(autoincrement())
  estudoId       Int    @map("estudo_id")
  participanteId Int    @map("participante_id")
  codigo         String @db.VarChar(20)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  estudo       Estudo       @relation(fields: [estudoId], references: [id], onDelete: Cascade)
  participante Participante @relation(fields: [participanteId], references: [id], onDelete: Restrict)

  visitas Visita[]

  @@unique([estudoId, participanteId])
  @@unique([estudoId, codigo])
  @@map("participacoes_estudo")
}

model PermissaoEstudo {
  id        Int       @id @default(autoincrement())
  papel     Papel     @default(viewer)
  estudoId  Int       @map("estudo_id")
  usuarioId Int       @map("usuario_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  estudo  Estudo  @relation(fields: [estudoId], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([estudoId, usuarioId])
  @@map("permissoes_estudo")
}

model Medicao {
  id         Int       @id @default(autoincrement())
  variavelId Int       @map("variavel_id")
  visitaId   Int       @map("visita_id")
  valorNum   Decimal?  @map("valor_num") @db.Decimal(10, 4)
  valorText  String?   @map("valor_text") @db.Text
  lado       String?   @db.VarChar(1)
  createdBy  Int       @map("created_by")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  variavel Variavel @relation(fields: [variavelId], references: [id], onDelete: Cascade)
  visita   Visita   @relation(fields: [visitaId], references: [id], onDelete: Cascade)
  usuario  Usuario  @relation(fields: [createdBy], references: [id], onDelete: Restrict)

  @@map("medicoes")
}
